{
  "name": "fintrust-backend",
  "version": "1.0.0",
  "description": "FinTrust Backend - Financial Management Platform for SMEs",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node src/server.ts",
