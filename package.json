    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
